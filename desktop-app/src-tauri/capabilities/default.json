{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos para la ventana principal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-open-url",
    "os:default",
    "os:allow-platform",
    "os:allow-os-type",
    "core:window:allow-start-dragging"
  ]
}
